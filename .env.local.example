# Copia questo file e rinominalo in ".env.local"
# Poi incolla qui le tue chiavi (senza virgolette).
# Questo file NON deve mai finire su GitHub (è già escluso da .gitignore).

# Chiave dell'API di Anthropic (console.anthropic.com) — resta SEGRETA, solo server.
ANTHROPIC_API_KEY=sk-ant-la-tua-chiave-qui

# Supabase (Project Settings -> API)
# ATTENZIONE: i nomi sono cambiati rispetto a prima.
# Servono l'URL e la chiave PUBBLICA (anon / publishable), non quella segreta.
# Il prefisso NEXT_PUBLIC_ è obbligatorio: dice a Next.js che possono
# stare anche nel browser (la chiave anon è pubblica per design).
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=la-tua-chiave-anon-pubblica

# Deepgram, per la trascrizione audio + riconoscimento di chi parla (console.deepgram.com)
# 200$ di credito gratuito all'iscrizione. Resta SEGRETA, solo server.
DEEPGRAM_API_KEY=la-tua-chiave-deepgram
